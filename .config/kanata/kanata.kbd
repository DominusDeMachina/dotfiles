(defsrc
  a s d f j k l ;)

(deflayer default
  @a @s @d @f @j @k @l @;)

(defalias
  a (tap-hold-release 150 150 a lsft)
  s (tap-hold-release 150 150 s lctl)
  d (tap-hold-release 150 150 d lalt)
  f (tap-hold-release 150 150 f lmet)
  j (tap-hold-release 150 150 j rmet)
  k (tap-hold-release 150 150 k ralt)
  l (tap-hold-release 150 150 l rctl)
  ; (tap-hold-release 150 150 ; rsft))
