[user]
	name = Gennadiy Furduy
	email = gfurduy@jhacorp.com
	mail = gennadiyfurduy@gmail.com

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	line-numbers = true
	syntax-theme = Catppuccin Mocha
	side-by-side = false

[merge]
	conflictStyle = zdiff3

[diff]
	colorMoved = default
